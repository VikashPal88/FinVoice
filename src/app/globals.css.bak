@import "tailwindcss";

@theme inline {
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --color-surface: var(--surface);
  --color-surface-hover: var(--surface-hover);
  --color-border: var(--border-color);
  --color-muted: var(--muted);
  --color-primary: #6366f1;
  --color-primary-hover: #818cf8;
  --color-income: #22c55e;
  --color-income-bg: rgba(34, 197, 94, 0.1);
  --color-expense: #ef4444;
  --color-expense-bg: rgba(239, 68, 68, 0.1);
  --color-accent: #8b5cf6;
  --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
}

/* Dark theme (default) */
:root {
  --background: #06060a;
  --foreground: #f0f0f5;
  --surface: rgba(255, 255, 255, 0.04);
  --surface-hover: rgba(255, 255, 255, 0.07);
  --border-color: rgba(255, 255, 255, 0.08);
  --muted: #71717a;
  --card-bg: rgba(255, 255, 255, 0.03);
  --sidebar-bg: rgba(255, 255, 255, 0.02);
  --glass-bg: rgba(255, 255, 255, 0.05);
  --glass-border: rgba(255, 255, 255, 0.1);
  --input-bg: rgba(255, 255, 255, 0.06);
  --dropdown-bg: #18181b;
  --tooltip-bg: #27272a;
  --shadow-color: rgba(0, 0, 0, 0.3);
}

/* Light theme */
[data-theme="light"] {
  --background: #f8fafc;
  --foreground: #0f172a;
  --surface: rgba(0, 0, 0, 0.03);
  --surface-hover: rgba(0, 0, 0, 0.06);
  --border-color: rgba(0, 0, 0, 0.08);
  --muted: #64748b;
  --card-bg: #ffffff;
  --sidebar-bg: #ffffff;
  --glass-bg: rgba(255, 255, 255, 0.7);
  --glass-border: rgba(0, 0, 0, 0.08);
  --input-bg: rgba(0, 0, 0, 0.04);
  --dropdown-bg: #ffffff;
  --tooltip-bg: #1e293b;
  --shadow-color: rgba(0, 0, 0, 0.08);
}

* {
  scrollbar-width: thin;
  scrollbar-color: rgba(113, 113, 122, 0.3) transparent;
}

*::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

*::-webkit-scrollbar-track {
  background: transparent;
}

*::-webkit-scrollbar-thumb {
  background: rgba(113, 113, 122, 0.3);
  border-radius: 3px;
}

*::-webkit-scrollbar-thumb:hover {
  background: rgba(113, 113, 122, 0.5);
}

html, body {
  height: 100%;
  overflow: hidden;
}

body {
  background: var(--background);
  color: var(--foreground);
  font-family: var(--font-sans);
}

/* Glass card effect */
.glass-card {
  background: var(--card-bg);
  border: 1px solid var(--glass-border);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-radius: 16px;
  box-shadow: 0 4px 24px var(--shadow-color);
}

.glass-card-sm {
  background: var(--card-bg);
  border: 1px solid var(--glass-border);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border-radius: 12px;
}

/* Gradient text */
.gradient-text {
  background: linear-gradient(135deg, #6366f1, #8b5cf6, #a78bfa);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* Glow effects */
.glow-primary {
  box-shadow: 0 0 20px rgba(99, 102, 241, 0.15), 0 0 60px rgba(99, 102, 241, 0.05);
}

.glow-income {
  box-shadow: 0 0 20px rgba(34, 197, 94, 0.15);
}

.glow-expense {
  box-shadow: 0 0 20px rgba(239, 68, 68, 0.15);
}

/* Recharts overrides */
.recharts-cartesian-grid-horizontal line,
.recharts-cartesian-grid-vertical line {
  stroke: var(--border-color) !important;
}

.recharts-text {
  fill: var(--muted) !important;
  font-size: 12px !important;
}

.recharts-tooltip-wrapper {
  outline: none !important;
}

/* Animation utilities */
@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6px); }
}

@keyframes pulse-glow {
  0%, 100% { box-shadow: 0 0 20px rgba(99, 102, 241, 0.1); }
  50% { box-shadow: 0 0 40px rgba(99, 102, 241, 0.25); }
}

.animate-shimmer {
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.05), transparent);
  background-size: 200% 100%;
  animation: shimmer 2s infinite;
}

/* No data */
.empty-state-icon {
  background: linear-gradient(135deg, var(--surface), var(--surface-hover));
  border-radius: 50%;
}

/* Custom select */
select {
  background-color: var(--input-bg);
  color: var(--foreground);
  border: 1px solid var(--glass-border);
}

select option {
  background-color: var(--dropdown-bg);
  color: var(--foreground);
}

input {
  background-color: var(--input-bg);
  color: var(--foreground);
  border: 1px solid var(--glass-border);
}

input::placeholder {
  color: var(--muted);
}

input:focus, select:focus {
  outline: none;
  border-color: #6366f1;
  box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
}

/* Modal backdrop */
.modal-backdrop {
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
}

/* Page transition background accent */
.bg-grid {
  background-image: 
    linear-gradient(rgba(99, 102, 241, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(99, 102, 241, 0.03) 1px, transparent 1px);
  background-size: 64px 64px;
}

[data-theme="light"] .bg-grid {
  background-image: 
    linear-gradient(rgba(99, 102, 241, 0.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(99, 102, 241, 0.05) 1px, transparent 1px);
}
